# ═══════════════════════════════════════
# 트레이딩 시스템 환경변수
# ═══════════════════════════════════════

# 트레이딩 모드: paper(모의투자) 또는 live(실전)
TRADING_MODE=paper

# ─── KIS API (모의투자) ───
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT_NO=          # 계좌번호 (예: 50012345-01)
KIS_PAPER_ACCOUNT_PRODUCT_CODE=01

# ─── KIS API (실전) ───
KIS_LIVE_APP_KEY=
KIS_LIVE_APP_SECRET=
KIS_LIVE_ACCOUNT_NO=
KIS_LIVE_ACCOUNT_PRODUCT_CODE=01

# ─── PostgreSQL ───
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading
POSTGRES_USER=trading
POSTGRES_PASSWORD=             # 반드시 강력한 비밀번호 설정

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=                # 선택사항

# ─── LLM API 키 ───
GEMINI_API_KEY=                # 메인 LLM (Google Gemini)
ANTHROPIC_API_KEY=             # 백업 LLM (Claude) — 선택
OPENAI_API_KEY=                # 백업 LLM (GPT) — 선택

# ─── 외부 데이터 API ───
FRED_API_KEY=                  # FRED API 키 (선택, 없으면 Yahoo로 대체)

# ─── 텔레그램 봇 ───
TELEGRAM_BOT_TOKEN=            # @BotFather에서 발급
TELEGRAM_CHAT_ID=              # 알림 받을 채팅 ID

# ─── Grafana ───
GRAFANA_PASSWORD=admin         # Grafana 관리자 비밀번호
